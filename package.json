{
  "name": "tesano-community-library",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test:connection": "node check-database.js",
    "diagnose": "node diagnose-connection.js",
    "connection-guide": "node connection-guide.js",
    "fix-database": "node connection-guide.js && node diagnose-connection.js",
    "verify-production": "node verify-production.js",
    "fix-cloudinary": "node fix-cloudinary-urls.js",
    "test-deployment": "node test-deployment.js",
    "test-email": "node test-email.js",
    "test-dashboard": "node test-dashboard.js",
    "add-timestamps": "node add-timestamps.js",
    "migrate": "node migrations/add-created-at-to-public-users.js",
    "migrate:old": "node migrations/run-migrations.js",
    "migrate:single": "node migrations/add-created-at-column.js",
    "add-indexes": "node add-indexes.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@getbrevo/brevo": "^3.0.1",
    "@google-cloud/storage": "^5.18.3",
    "@sendgrid/mail": "^8.1.5",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.5",
    "buffer-crc32": "^1.0.0",
    "cloudinary": "^2.8.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^5.5.1",
    "express-session": "^1.18.2",
    "express-validator": "^7.2.1",
    "googleapis": "^159.0.0",
    "install": "^0.13.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^9.0.3",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.16.3",
    "python-shell": "^5.0.0",
    "resend": "^6.12.3",
    "streamifier": "^0.1.1",
    "uid2": "^1.0.0",
    "winston": "^3.18.3"
  },
  "description": "Online Library Management System for the Tesano Community",
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/__tests__/**",
      "!node_modules/**"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/?(*.)+(spec|test).js"
    ],
    "testTimeout": 10000,
    "setupFilesAfterEnv": [
      "./jest.setup.js"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/jest": "^30.0.0",
    "eslint": "^9.35.0",
    "globals": "^16.2.0",
    "jest": "^30.2.0",
    "supertest": "^7.1.4"
  }
}
